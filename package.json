{
  "name": "routine-quest",
  "version": "0.1.0",
  "private": true,
  "description": "A lean, JSON-driven gamified daily/weekly routine tracker.",
  "main": "src/app.ts",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx src/app.ts",
    "start": "tsx src/app.ts",
    "build": "prisma generate",
    "vercel-build": "prisma migrate deploy && prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:verify": "tsx scripts/verify-prisma.ts",
    "seed": "prisma db seed",
    "test:rules": "tsx scripts/phase2-rules-check.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
